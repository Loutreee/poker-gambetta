generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  role         String        @default("player") // "player" | "dealer" | "admin"
  passwordHash String        @map("password_hash")
  avatarUrl    String?       @map("avatar_url")
  bio          String?       @map("bio")
  createdAt    DateTime      @default(now()) @map("created_at")

  entriesAsTarget  LedgerEntry[] @relation("EntryTarget")
  entriesAsCreator LedgerEntry[] @relation("EntryCreator")

  sessionEntries   SessionEntry[]
  arcMonkeyPlayer ArcMonkeyPlayer?
  bets            Bet[]

  @@map("users")
}

model LedgerEntry {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  amount    Int      // en centimes ou unités (ex: +10, -5)
  note      String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @map("created_by")

  sessionId String?  @map("session_id")

  user   User @relation("EntryTarget", fields: [userId], references: [id], onDelete: Cascade)
  author User @relation("EntryCreator", fields: [createdBy], references: [id])
  session Session? @relation(fields: [sessionId], references: [id])

  @@map("ledger_entries")
}

model Session {
  id        String         @id @default(cuid())
  type      String                     // "sitngo" | "tournoi"
  name      String?                    // nom optionnel
  status    String         @default("open") // "open" | "closed"
  createdAt DateTime       @default(now()) @map("created_at")
  closedAt  DateTime?      @map("closed_at")

  entries   SessionEntry[]
  ledger    LedgerEntry[]

  @@map("sessions")
}

model SessionEntry {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  userId    String   @map("user_id")
  buyIn     Int      @default(0) @map("buy_in")
  rebuy     Int      @default(0)
  result    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("session_entries")
}

model BadgeOverride {
  id          String   @id @default(cuid())
  badgeId     String   @unique @map("badge_id")
  name        String?  @map("name")
  description String?  @map("description")
  bgColor     String?  @map("bg_color")
  iconColor   String?  @map("icon_color")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("badge_overrides")
}

model ArcMonkeyPlayer {
  id               String   @id @default(cuid())
  name             String   @unique
  steamProfileUrl  String?  @map("steam_profile_url")
  steamDisplayName String?  @map("steam_display_name")
  steamAvatarUrl   String?  @map("steam_avatar_url")
  userId           String?  @unique @map("user_id")
  active           Boolean  @default(true)

  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  matchPlayers  MatchPlayer[]
}

model Match {
  id          String   @id @default(cuid())
  title       String?  // titre optionnel du match
  opponent    String
  format      String   @default("BO3") // "BO1" | "BO3" | "BO5"
  scheduledAt DateTime @map("scheduled_at")
  status      String   @default("upcoming") // "upcoming" | "finished" | "cancelled"
  createdAt   DateTime @default(now()) @map("created_at")

  // Lien vers la salle de match (Faceit, ESEA, etc.) pour automatiser le règlement
  faceitMatchUrl String? @map("faceit_match_url")

  // Limites de mise (optionnel, 0 = pas de limite). Configurable en admin.
  maxStakePerBet   Int? @map("max_stake_per_bet")   // plafond par pari
  maxStakePerMatch Int? @map("max_stake_per_match") // plafond total par user sur ce match

  players MatchPlayer[]
  bets    Bet[]
}

model Bet {
  id        String   @id @default(cuid())
  matchId   String   @map("match_id")
  userId    String   @map("user_id")
  amount    Int      // mise en unités (même échelle que ledger)
  betType   String   @map("bet_type") // "VICTORY" | "PLAYER_RANK" | "KILLS" | "ACE" | "EXACT_SCORE"
  payload   Json     // données selon le type (outcome, playerId, rank, threshold, score…)
  status    String   @default("PENDING") // "PENDING" | "WON" | "LOST" | "CANCELLED"
  createdAt DateTime @default(now()) @map("created_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([userId])
}

model MatchPlayer {
  id       String @id @default(cuid())
  matchId  String @map("match_id")
  playerId String @map("player_id")

  match  Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player ArcMonkeyPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
}


