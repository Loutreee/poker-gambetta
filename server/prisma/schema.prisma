generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  role         String        @default("player") // "player" | "dealer" | "admin"
  passwordHash String        @map("password_hash")
  avatarUrl    String?       @map("avatar_url")
  bio          String?       @map("bio")
  createdAt    DateTime      @default(now()) @map("created_at")

  entriesAsTarget  LedgerEntry[] @relation("EntryTarget")
  entriesAsCreator LedgerEntry[] @relation("EntryCreator")

  sessionEntries   SessionEntry[]

  @@map("users")
}

model LedgerEntry {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  amount    Int      // en centimes ou unités (ex: +10, -5)
  note      String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @map("created_by")

  sessionId String?  @map("session_id")

  user   User @relation("EntryTarget", fields: [userId], references: [id], onDelete: Cascade)
  author User @relation("EntryCreator", fields: [createdBy], references: [id])
  session Session? @relation(fields: [sessionId], references: [id])

  @@map("ledger_entries")
}

model Session {
  id        String         @id @default(cuid())
  type      String                     // "sitngo" | "tournoi"
  name      String?                    // nom optionnel
  status    String         @default("open") // "open" | "closed"
  createdAt DateTime       @default(now()) @map("created_at")
  closedAt  DateTime?      @map("closed_at")

  entries   SessionEntry[]
  ledger    LedgerEntry[]

  @@map("sessions")
}

model SessionEntry {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  userId    String   @map("user_id")
  buyIn     Int      @default(0) @map("buy_in")
  rebuy     Int      @default(0)
  result    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("session_entries")
}

