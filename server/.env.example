# Base de données PostgreSQL (obligatoire)
DATABASE_URL=postgresql://poker:poker@localhost:5432/poker

# JWT pour les cookies de session (obligatoire, changer en prod)
JWT_SECRET=dev-secret

# CORS : origines autorisées, séparées par des virgules (ex: http://localhost:5173,http://localhost:5174)
# En dev avec npm run dev:all : Poker (5173) et Betting (5174) pointent vers l’API.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Clé API Steam pour pseudo/avatar des joueurs ArcMonkey (optionnel)
# https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Clé API Faceit Data pour le règlement automatique des paris (optionnel)
# https://developers.faceit.com/
FACEIT_API_KEY=
