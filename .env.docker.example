# Copier en .env à la racine pour docker compose (prod ou staging).
# Utilisé par : docker compose up -d --build

# --- Obligatoire ---
JWT_SECRET=change-me-utiliser-une-vraie-secret-long
CORS_ORIGIN=https://poker.example.com,https://betting.example.com

# --- URLs des fronts (au build, pour les liens Poker ↔ Betting) ---
VITE_BETTING_APP_URL=https://betting.example.com
VITE_POKER_APP_URL=https://poker.example.com

# --- Optionnel ---
# FACEIT_API_KEY=
# STEAM_API_KEY=
