{
  "name": "poker-gambetta",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:poker": "cross-env VITE_PROXY_TARGET=http://localhost:3001 npm run dev --prefix apps/poker-gambetta",
    "dev:betting": "cross-env VITE_PROXY_TARGET=http://localhost:3001 npm run dev --prefix apps/betting-gambetta",
    "dev:server": "cd server && npm run dev",
    "dev:db": "node scripts/ensure-db.cjs",
    "dev:all": "npm run dev:db && concurrently -n api,poker,betting -c blue,green,magenta --kill-others \"cross-env PORT=3001 npm run dev --prefix server\" \"npm run dev:poker\" \"npm run dev:betting\"",
    "build:poker": "npm run build --prefix apps/poker-gambetta",
    "build:betting": "npm run build --prefix apps/betting-gambetta",
    "build": "npm run build:poker && npm run build:betting && cd server && npm run build",
    "lint": "eslint .",
    "preview:poker": "npm run preview --prefix apps/poker-gambetta",
    "preview:betting": "npm run preview --prefix apps/betting-gambetta"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/react-query": "^5.90.21",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.0.0",
    "lucide-react": "^0.577.0",
    "partycles": "^1.2.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
